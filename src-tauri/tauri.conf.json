{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "meeting-notes-tauri",
  "version": "0.1.0",
  "identifier": "de.schirkan.meeting-notes-tauri",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Meeting Notes (Tauri)",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar/publish/sidecar/*": "sidecar/"
    }
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
